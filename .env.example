# ============================================
# ContentEngine Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ---------- General ----------
ENVIRONMENT=development
LOG_LEVEL=debug

# ---------- Database ----------
POSTGRES_USER=cme
POSTGRES_PASSWORD=cme_dev_password
POSTGRES_DB=contentengine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cme:cme_dev_password@localhost:5432/contentengine

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Auth / JWT ----------
JWT_SECRET=dev-secret-change-in-production-must-be-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_GROWTH=price_growth_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---------- AI ----------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------- Platform OAuth (Future) ----------
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
