# ============================================
# Pandocast Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ---------- General ----------
ENVIRONMENT=development
LOG_LEVEL=debug

# ---------- Database ----------
POSTGRES_USER=pando
POSTGRES_PASSWORD=pando_dev_password
POSTGRES_DB=pandocast
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pando:pando_dev_password@localhost:5432/pandocast

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Auth / JWT ----------
JWT_SECRET=dev-secret-change-in-production-must-be-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_GROWTH=price_growth_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---------- AI ----------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------- Token Encryption ----------
TOKEN_ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---------- Backend URL ----------
BACKEND_URL=http://localhost:8000

# ---------- Platform OAuth ----------
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
MEDIUM_CLIENT_ID=
MEDIUM_CLIENT_SECRET=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# ---------- Firebase Backend ----------
FIREBASE_SERVICE_ACCOUNT_BASE64=  # Base64-encoded service account JSON: base64 -i path/to/service-account.json | tr -d '\n'
FIREBASE_STORAGE_BUCKET=  # e.g., your-project-id.firebasestorage.app

# ---------- Firebase Frontend (NEXT_PUBLIC_) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=  # e.g., your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=  # same as FIREBASE_STORAGE_BUCKET above
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=  # From Project Settings > Cloud Messaging > Web Push certificates
